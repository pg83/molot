#!/bin/sh
set -eux

: "${AWS_ACCESS_KEY_ID:?}"
: "${AWS_SECRET_ACCESS_KEY:?}"
: "${S3_ENDPOINT:?}"
: "${S3_BUCKET:?}"
: "${MOLOT_S3_ROOT:?}"

S3_SCHEME="${S3_ENDPOINT%%://*}"
S3_HOST="${S3_ENDPOINT#*://}"
export MC_HOST_molot="${S3_SCHEME}://${AWS_ACCESS_KEY_ID}:${AWS_SECRET_ACCESS_KEY}@${S3_HOST}"

echo "molot: whoami=$(whoami) pwd=$(pwd) home=$HOME" >&2
T=$(mktemp -d "$(pwd)/molot.XXXXXXXX")
trap 'rm -rf "$T"' EXIT
export T

: "${MOLOT_CPUS:?}"
export MOLOT_MAKE_THRS="${MOLOT_CPUS}"

cat > "$T/inner.sh" <<'MOLOT_INNER_EOF'
#!/bin/sh
set -eux
export PATH=/bin:/ix/realm/system/bin:${PATH:-}

# Fresh tmpfs as overlayfs upper/work, mounted inside the user+mount ns.
# A tmpfs created in this ns reliably supports user.overlay.* xattrs
# (needed for whiteouts with userxattr mode); the host's /var/run tmpfs
# may not. Overlay lowerdir stays at host's /ix/store so realm symlinks
# (/bin -> /ix/realm/system/bin -> /ix/store/<busybox>/...) keep resolving.
mkdir -p "$T/ovl"
mount -t tmpfs tmpfs "$T/ovl"
mkdir -p "$T/ovl/upper" "$T/ovl/work"

# Mark only the OUT dir opaque — it's the one the cmd writes into
# (and rm -rfs), and hiding lower there avoids EACCES on whiteouts
# in the rootless overlay. Must be done BEFORE mounting overlay and
# directly on the upper path: in userxattr mode overlay itself
# rejects writes to user.overlay.* via the overlay mount.
#
# Dep IN_dirs are NOT marked opaque. The cmd only reads them; if the
# S3 artifact we extract into upper is incomplete, overlayfs falls
# through to the host's lower copy (same uid, same CAS content).
# This keeps builds from face-planting on a single corrupted upload.
{{range $i, $in := .InDirs -}}
mkdir -p {{shUpper $in}}
{{end -}}
mkdir -p {{shUpper .Out}}
setfattr -n user.overlay.opaque -v y {{shUpper .Out}}

mount -t overlay overlay \
    -o "lowerdir=/ix/store,upperdir=$T/ovl/upper,workdir=$T/ovl/work,userxattr" \
    /ix/store

# IX build scripts expect ${tmp}=/ix/build/<uid> to be writable scratch.
# Stock IX wraps builds with bin/ix/tmpfs which does exactly this; we do
# it here since molot expects the graph to be generated with
# IX_FLAGS=stalix= (no confine/tmpfs wrap — nested unshare inside our
# user ns caused EACCES on overlay whiteouts).
mount -t tmpfs tmpfs /ix/build

# Remount /proc, /dev, /sys as *rbind* copies. Without this, inside
# our user ns they're the parent ns's mounts — /proc in particular
# reports the parent's uid_map, so anything reading /proc/self/status
# or /proc/self/uid_map sees UIDs we didn't expect. Rbind gives us
# independent views with our ns's semantics. Matches what jail.sh
# does explicitly for its rootfs.
mount --rbind /proc /proc
mount --rbind /sys /sys
mount --rbind /dev /dev

{{range $i, $in := .InDirs -}}
minio-client cp {{depS3 $in}} {{archT $i}}
tar --use-compress-program=unzstd -xf {{archT $i}} -C {{shStore $in}}
rm -f {{archT $i}}
{{end}}

cd /

{{range $i, $c := .Cmds -}}
# cmd {{$i}}
printf %s {{stdinB64 $c}} | base64 -d | {{if not $.Net}}/bin/unshare -r -n {{end}}{{cmdLine $c}}
{{end}}

tar --use-compress-program=zstd -cf {{outT}} -C {{shStore .Out}} .
minio-client cp {{outT}} {{selfS3 .UID}}
MOLOT_INNER_EOF
chmod +x "$T/inner.sh"

unshare -r -U -m "$T/inner.sh"
